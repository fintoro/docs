{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Fintoro Public API",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#166534"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "seo": {
    "title": "Fintoro Public API dokumentácia",
    "description": "Public API dokumentácia pripravená na produkčné integrácie s Fintoro.",
    "image": "/images/og-image.png"
  },
  "navigation": {
    "languages": [
      {
        "language": "cs",
        "tabs": [
          {
            "tab": "Príručky",
            "groups": [
              {
                "group": "Začíname",
                "pages": [
                  "index",
                  "getting-started",
                  "authentication",
                  "sandbox-testing"
                ]
              },
              {
                "group": "Prevádzka",
                "pages": [
                  "conventions",
                  "errors-and-idempotency",
                  "webhooks",
                  "reference-tables"
                ]
              }
            ]
          },
          {
            "tab": "API referencia",
            "groups": [
              {
                "group": "Prehľad",
                "pages": [
                  "api-reference/index"
                ]
              },
              {
                "group": "Endpointy",
                "openapi": {
                  "source": "openapi.yaml",
                  "directory": "api-reference"
                }
              }
            ]
          }
        ]
      },
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting started",
                "pages": [
                  "en/index",
                  "en/getting-started",
                  "en/authentication",
                  "en/sandbox-testing"
                ]
              },
              {
                "group": "Operations",
                "pages": [
                  "en/conventions",
                  "en/errors-and-idempotency",
                  "en/webhooks",
                  "en/reference-tables"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "en/api-reference/index"
                ]
              },
              {
                "group": "Endpoints",
                "openapi": {
                  "source": "en/openapi.yaml",
                  "directory": "en/api-reference"
                }
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Fintoro",
          "href": "https://fintoro.sk",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://app.fintoro.sk"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
